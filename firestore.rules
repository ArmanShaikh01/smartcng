rules_version = '2';

// ══════════════════════════════════════════════════════════════════
//   SMART CNG STATION — Firestore Security Rules
//   Production-ready | Blaze Plan | Play Store / TWA Safe
//   Last updated: 2026-02-22
// ══════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Shared helper functions ──────────────────────────────────────

    // Is the request made by a signed-in user?
    function isAuth() {
      return request.auth != null;
    }

    // Is the signed-in user the owner of this document?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Fetch the caller's role from Firestore safely.
    // Returns null if the user document does not exist yet
    // (brand-new users who haven't completed signup).
    // Using exists() prevents permission-denied errors during
    // the new-user registration flow.
    function callerRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin()    { return isAuth() && callerRole() == 'admin'; }
    function isOperator() { return isAuth() && callerRole() == 'operator'; }
    function isOwnerRole(){ return isAuth() && callerRole() == 'owner'; }

    // Is the caller either admin, owner-role, or operator?
    function isStaff() {
      return isAuth() && callerRole() in ['admin', 'owner', 'operator'];
    }

    // Does the incoming data contain a specific key?
    function hasField(field) {
      return field in request.resource.data;
    }

    // Does the update attempt to modify a restricted field?
    function notChanging(field) {
      return !(field in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ────────────────────────────────────────────────────────────────
    //   /users/{userId}
    // ────────────────────────────────────────────────────────────────
    match /users/{userId} {

      // READ (single document): own doc OR admin
      allow read: if isOwner(userId) || isAdmin();

      // LIST (collection query): allow authenticated users to query
      // by phoneNumber so useAuth.jsx can find admin-created operator/owner
      // accounts (phone-keyed) and migrate them to UID-keyed docs.
      allow list: if isAuth();

      // CREATE — three allowed cases:
      //   1. User creates their own UID doc (customer self-registration)
      //      Cannot self-assign privileged role or banned fields.
      //   2. Owner creates an operator doc (any auto-generated doc ID)
      //   3. First-login UID migration: operator/owner creating their own
      //      UID-keyed doc from a phone-keyed doc (useAuth.jsx fallback path).
      //      Doc ID must be their UID and phone must match verified token.
      allow create: if
        // Case 1: self-registration as customer
        (isOwner(userId)
          && (!hasField('role') || request.resource.data.role == 'customer')
          && !hasField('isBanned')
          && !hasField('bannedUntil')
          && !hasField('noShowCount'))
        ||
        // Case 2: owner adds a new operator (pre-login, auto-generated doc ID)
        (isOwnerRole() && request.resource.data.role == 'operator')
        ||
        // Case 3: first-login UID migration for operator/owner accounts
        //   useAuth.jsx does: setDoc(uid-doc, {...phoneDoc, userId: uid})
        //   Safe: doc ID == caller UID + phone matches verified Firebase token
        (isAuth()
          && userId == request.auth.uid
          && request.resource.data.phoneNumber == request.auth.token.phone_number
          && request.resource.data.role in ['operator', 'owner', 'admin']);

      // UPDATE: own doc only — locked fields can never be self-modified
      allow update: if isOwner(userId)
        && notChanging('role')
        && notChanging('isBanned')
        && notChanging('bannedUntil')
        && notChanging('noShowCount');

      // ADMIN override: full read/write for user management panel
      allow write: if isAdmin();

      // DELETE — three allowed cases:
      //   1. Account self-deletion: user deletes their own UID-keyed doc
      //      (happens during the "Delete My Account" flow in Profile.jsx)
      //   2. Legacy migration: user deletes an old phone-keyed doc during
      //      first-login UID migration (the doc ID is NOT their UID but
      //      the phoneNumber matches their verified Firebase Auth phone)
      //   3. Owner removes an operator from their station
      allow delete: if isAuth() && (
        // Case 1: deleting own UID-keyed doc (account deletion)
        resource.id == request.auth.uid
        ||
        // Case 2: deleting legacy phone-keyed doc (UID migration)
        (resource.data.phoneNumber == request.auth.token.phone_number
          && resource.id != request.auth.uid)
        ||
        // Case 3: owner deletes an operator document
        (isOwnerRole() && resource.data.role == 'operator')
      );
    }

    // ────────────────────────────────────────────────────────────────
    //   /stations/{stationId}
    // ────────────────────────────────────────────────────────────────
    match /stations/{stationId} {

      // READ: all authenticated users (customers/operators/owners need station data)
      allow read: if isAuth();

      // CREATE / DELETE: admin only
      allow create, delete: if isAdmin();

      // UPDATE:
      //   Admin: any field
      //   Owner: any field
      //   Operator: only safe operational toggle fields (gasOn, bookingOn, counters)
      //   NOTE: We skip the stationId match check because the Firestore doc ID
      //         differs from the custom stationId field value in the operator's doc,
      //         making a reliable station-match impossible in rules alone.
      //         Field-level restriction (onlyUpdatingOperationalFields) keeps this safe.
      allow update: if isAdmin()
        || isOwnerRole()
        || (isOperator() && onlyUpdatingOperationalFields());

      // Operators may only touch these operational fields — no sensitive data exposed
      function onlyUpdatingOperationalFields() {
        let allowed = ['gasOn', 'bookingOn', 'totalVehiclesServed',
                       'totalSkips', 'slotCapacity', 'updatedAt'];
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
      }
    }

    // ────────────────────────────────────────────────────────────────
    //   /bookings/{bookingId}
    // ────────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {

      // READ (single document): own booking or staff
      allow get: if isAuth() && (
        resource.data.customerId == request.auth.uid
        || isStaff()
      );

      // LIST (collection queries for queue panel / analytics):
      //   resource is null during list evaluation — must not reference resource.data.
      //   Security is enforced by app-side query filters (customerId == uid for customers).
      allow list: if isAuth();

      // CREATE: authenticated user; must set customerId to their own UID
      //   Prevents creating bookings on behalf of others
      allow create: if isAuth()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.stationId is string
        && request.resource.data.vehicleNumber is string
        && request.resource.data.status in ['waiting', 'eligible']
        && !hasField('isBanned');

      // UPDATE:
      //   Customer → can only cancel or check-in their own booking
      //   Customer → can shift queuePosition on ANY booking (needed for
      //              cancellation re-index writeBatch — only positional fields)
      //   Operator/Admin → can update status fields (fueling, complete, skip, no-show)
      allow update: if
        // Customer cancels or checks in their own booking
        (isAuth()
          && resource.data.customerId == request.auth.uid
          && onlyCustomerFields())
        // Customer re-indexes sibling bookings after cancellation:
        //   Only queuePosition + updatedAt are allowed — no status/customerId changes.
        //   This is required because cancelBooking() uses a writeBatch that must
        //   shift positions on other customers' bookings atomically.
        || (isAuth() && onlyQueueReindex())
        // Operator or Admin updates queue status
        || isStaff();

      // DELETE: nobody deletes bookings (soft-delete via status field)
      allow delete: if false;

      // Customer can only modify these fields on their own booking
      function onlyCustomerFields() {
        let allowed = ['status', 'isCheckedIn', 'checkedInAt', 'checkInLocation', 'updatedAt',
                        'lanePosition', 'fuelingStartedAt', 'cancelledAt'];
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
      }

      // Queue re-index after cancellation: only positional fields, no sensitive data
      // Prevents abuse: cannot change status, customerId, vehicleNumber, stationId, etc.
      function onlyQueueReindex() {
        let allowed = ['queuePosition', 'updatedAt'];
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
      }
    }

    // ────────────────────────────────────────────────────────────────
    //   /queue_logs/{logId}
    // ────────────────────────────────────────────────────────────────
    match /queue_logs/{logId} {

      // READ: staff only (admin, owner, operator — for SystemLogs panel)
      allow read: if isStaff();

      // CREATE: any authenticated user (customers + operators write logs)
      //   Must include required fields; cannot forge performedBy
      allow create: if isAuth()
        && request.resource.data.performedBy == request.auth.uid
        && request.resource.data.action is string
        && request.resource.data.timestamp != null;

      // Logs are immutable — no update or delete
      allow update, delete: if false;
    }

    // ────────────────────────────────────────────────────────────────
    //   /notifications/{userId}/items/{notifId}
    //
    //   IMPORTANT: The code uses a SUBCOLLECTION structure:
    //     notifications/{userId}/items/{notifId}
    //   NOT a flat collection. Rules must match this exact path.
    // ────────────────────────────────────────────────────────────────
    match /notifications/{userId} {
      // The parent doc itself — allow authenticated owner to read/write
      // (needed so Firestore can traverse the path to the subcollection)
      allow read, write: if isOwner(userId) || isAdmin();

      match /items/{notifId} {

        // READ (single document): owner of this notification or admin
        allow get: if isOwner(userId) || isAdmin();

        // LIST (collection queries — unread count, notification panel):
        //   Only the owner of the UID bucket or admin can list their items
        allow list: if isOwner(userId) || isAdmin();

        // CREATE: any authenticated user can push to any user's notification bucket.
        //   This is intentional — it enables:
        //     - Operators notifying owners (NEXT button)
        //     - Owners notifying operators (skip/complete)
        //     - Customers notifying operators (GPS check-in)
        //   All users have verified phone numbers; notification data is non-sensitive.
        //   READ/UPDATE/DELETE remain strictly per-owner below.
        allow create: if isAuth();

        // UPDATE: owner only — e.g., marking as read
        allow update: if isOwner(userId) && onlyMarkingRead();

        // DELETE: owner only
        allow delete: if isOwner(userId);

        // Only allow the 'read' and 'readAt' fields to be updated
        // (matches the markNotificationRead schema: { read: true })
        function onlyMarkingRead() {
          let allowed = ['read', 'readAt'];
          return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
        }
      }
    }

    // ────────────────────────────────────────────────────────────────
    //   /ratings/{ratingId}
    //   Schema: { stationId, customerId, bookingId, rating, comment, createdAt }
    // ────────────────────────────────────────────────────────────────
    match /ratings/{ratingId} {
      // READ: any authenticated user (to compute avg on station cards)
      allow read: if isAuth();

      // CREATE: authenticated user, must set their own customerId
      //   One rating per booking is enforced app-side (alreadyRated check)
      allow create: if isAuth()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;

      // NO update or delete (ratings are immutable)
      allow update, delete: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────────
    //   /complaints/{complaintId}
    //   Schema: { customerId, stationId, bookingId, description,
    //             imageUrl, status, resolvedAt, createdAt }
    // ────────────────────────────────────────────────────────────────
    match /complaints/{complaintId} {
      // READ: own complaint (customer) OR admin OR staff (operators/owners)
      allow read: if isAuth()
        && (resource.data.customerId == request.auth.uid || isStaff() || isAdmin());

      // LIST: any authenticated staff member or the customer themselves
      allow list: if isAuth();

      // CREATE: authenticated user, must set own customerId
      allow create: if isAuth()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'pending';

      // UPDATE: admin OR staff (owner/operator) can mark as resolved
      //   Only allow changing status + resolvedAt field
      allow update: if isAdmin() || isStaff();

      // DELETE: not allowed
      allow delete: if false;
    }

    // ────────────────────────────────────────────────────────────────
    //   /audit_logs/{logId}
    //   Schema: { userId, role, actionType, description, stationId, createdAt }
    // ────────────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      // CREATE: staff (owner/operator) or admin can write logs
      allow create: if isAuth() && (isStaff() || isAdmin());
      // READ: staff of the same station or admin
      allow read: if isAuth() && (isStaff() || isAdmin());
      // No updates or deletes — audit logs are immutable
      allow update, delete: if false;
    }

    // ────────────────────────────────────────────────────────────────
    //   DENY ALL — catch-all for any other collection
    // ────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Complaint images ────────────────────────────────────────────
    //   Path: complaints/{userId}/{filename}
    //   Only the authenticated user can upload to their own folder.
    //   Max file size: 5 MB (enforced in the app, not checkable here directly).
    match /complaints/{userId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
